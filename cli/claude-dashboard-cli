#!/usr/bin/env bash
set -euo pipefail

# --- Configuration ---
VERSION="1.0.0"
DEFAULT_INTERVAL=300
CARD_WIDTH=46
BAR_WIDTH=16
API_BASE="https://claude.ai/api"

# --- Colors & Formatting ---
USE_COLOR=true
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
ORANGE='\033[38;5;208m'
GRAY='\033[38;5;245m'

# Box drawing
TL='┌' TR='┐' BL='└' BR='┘' H='─' V='│'

# Progress bar chars
FILLED='█'
EMPTY='░'

# --- Argument Parsing ---
INTERVAL=$DEFAULT_INTERVAL
ONCE=false
SHOW_HELP=false

while [[ $# -gt 0 ]]; do
    case $1 in
        sync)
            exec "$(dirname "$0")/claude-dashboard-helper" sync
            ;;
        --interval)
            INTERVAL="${2:?--interval requires a value}"
            shift 2
            ;;
        --once)
            ONCE=true
            shift
            ;;
        --no-color)
            USE_COLOR=false
            shift
            ;;
        --help|-h)
            SHOW_HELP=true
            shift
            ;;
        --version)
            echo "claude-dashboard-cli $VERSION"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

if $SHOW_HELP; then
    cat <<'EOF'
Usage: claude-dashboard-cli [command] [options]

Commands:
  sync              Scan Chrome for Claude sessions and save accounts
  (default)         Show usage dashboard

Options:
  --interval <sec>  Refresh interval in seconds (default: 300)
  --once            Show dashboard once and exit
  --no-color        Disable colors
  --version         Show version
  --help            Show this help
EOF
    exit 0
fi

if ! $USE_COLOR; then
    BOLD='' DIM='' RESET='' RED='' GREEN='' YELLOW='' BLUE='' PURPLE='' ORANGE='' GRAY=''
fi

# --- Locate helper binary ---
HELPER="$(dirname "$0")/claude-dashboard-helper"
if [[ ! -x "$HELPER" ]]; then
    # Try Homebrew location
    HELPER="$(brew --prefix 2>/dev/null)/bin/claude-dashboard-helper" 2>/dev/null || true
fi
if [[ ! -x "$HELPER" ]]; then
    echo "Error: claude-dashboard-helper not found." >&2
    echo "Install via: brew install haiz/claude-dashboard/claude-dashboard-cli" >&2
    exit 1
fi

# --- Helper Functions ---

color_for_pct() {
    local pct=$1
    if ! $USE_COLOR; then echo ""; return; fi
    local r g
    if (( pct <= 50 )); then
        r=$(( pct * 5 ))
        g=255
    else
        r=255
        g=$(( 255 - (pct - 50) * 5 ))
    fi
    (( r > 255 )) && r=255; (( r < 0 )) && r=0
    (( g > 255 )) && g=255; (( g < 0 )) && g=0
    printf '\033[38;2;%d;%d;0m' "$r" "$g"
}

plan_color() {
    local plan="$1"
    case "$plan" in
        Pro)       echo -ne "$BLUE" ;;
        "Max 5x")  echo -ne "$PURPLE" ;;
        "Max 20x") echo -ne "$ORANGE" ;;
        Max)       echo -ne "$PURPLE" ;;
        *)         echo -ne "$GRAY" ;;
    esac
}

progress_bar() {
    local pct=$1
    local filled=$(( pct * BAR_WIDTH / 100 ))
    (( filled > BAR_WIDTH )) && filled=$BAR_WIDTH
    local empty=$(( BAR_WIDTH - filled ))
    local color
    color=$(color_for_pct "$pct")

    printf '%b' "$color"
    for (( i=0; i<filled; i++ )); do printf '%s' "$FILLED"; done
    printf '%b' "$RESET$DIM"
    for (( i=0; i<empty; i++ )); do printf '%s' "$EMPTY"; done
    printf '%b' "$RESET"
}

format_reset_time() {
    local iso="$1"
    if [[ -z "$iso" || "$iso" == "null" ]]; then
        echo ""
        return
    fi
    # Parse ISO8601 and format as "Sat 3p"
    local epoch
    epoch=$(date -jf "%Y-%m-%dT%H:%M:%S" "${iso%%.*}" "+%s" 2>/dev/null) || \
    epoch=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "${iso%%.*}Z" "+%s" 2>/dev/null) || \
    epoch=$(date -jf "%Y-%m-%dT%H:%M:%S%z" "$iso" "+%s" 2>/dev/null) || {
        echo ""
        return
    }
    local day hour ampm
    day=$(date -r "$epoch" "+%a")
    hour=$(date -r "$epoch" "+%-I")
    ampm=$(date -r "$epoch" "+%p" | tr '[:upper:]' '[:lower:]' | head -c1)
    echo "${day} ${hour}${ampm}"
}

# --- Render Functions ---

render_header() {
    local timestamp
    timestamp=$(date "+%H:%M:%S")
    local left="Claude Dashboard"
    local right="refreshed $timestamp"
    local padding=$(( CARD_WIDTH - ${#left} - ${#right} - 1 ))
    printf ' %b%s%b' "$BOLD" "$left" "$RESET"
    for (( i=0; i<padding; i++ )); do printf ' '; done
    printf '%b%s%b\n' "$DIM" "$right" "$RESET"
    printf ' '
    for (( i=0; i<CARD_WIDTH; i++ )); do printf '%s' "$H"; done
    printf '\n'
}

render_card() {
    local name="$1" plan="$2" status="$3"
    local pct_5h="$4" reset_5h="$5"
    local pct_7d="$6" reset_7d="$7"
    local pct_sonnet="$8" reset_sonnet="$9"

    local pcolor
    pcolor=$(plan_color "$plan")

    # Header: ┌─ email ─────────── Plan ──┐
    local inner=$(( CARD_WIDTH - 2 ))
    local plan_part=" $plan "
    local name_part=" $name "
    # Truncate name if too long
    local max_name=$(( inner - ${#plan_part} - 4 ))
    if (( ${#name_part} > max_name )); then
        name_part=" ${name:0:$((max_name - 3))}.. "
    fi
    local dashes_needed=$(( inner - ${#name_part} - ${#plan_part} - 2 ))
    (( dashes_needed < 1 )) && dashes_needed=1

    printf ' %s%s' "$TL" "$H"
    printf '%b%s%b' "$BOLD" "$name_part" "$RESET"
    for (( i=0; i<dashes_needed; i++ )); do printf '%s' "$H"; done
    printf '%b%s%b' "$pcolor" "$plan_part" "$RESET"
    printf '%s%s\n' "$H" "$TR"

    if [[ "$status" != "active" ]]; then
        local msg="  Session $status"
        printf ' %s' "$V"
        printf '%b' "$DIM"
        printf '%-*s' "$inner" "$msg"
        printf '%b%s\n' "$RESET" "$V"
    else
        render_usage_row "5h" "$pct_5h" "$reset_5h"
        render_usage_row "7d" "$pct_7d" "$reset_7d"
        if [[ -n "$pct_sonnet" && "$pct_sonnet" != "null" && "$pct_sonnet" != "" ]]; then
            render_usage_row "S " "$pct_sonnet" "$reset_sonnet"
        fi
    fi

    # Footer
    printf ' %s' "$BL"
    for (( i=0; i<inner; i++ )); do printf '%s' "$H"; done
    printf '%s\n' "$BR"
}

render_usage_row() {
    local label="$1" pct_raw="$2" reset_str="$3"
    local pct=${pct_raw%.*}  # truncate decimals
    (( pct > 100 )) && pct=100
    (( pct < 0 )) && pct=0

    local inner=$(( CARD_WIDTH - 2 ))

    local reset_display=""
    if [[ -n "$reset_str" && "$reset_str" != "" ]]; then
        reset_display="resets $reset_str"
    fi

    local pct_str
    printf -v pct_str '%3d%%' "$pct"

    # "│  5h  ████████░░░░░░░░  52%  resets Sat 3p│"
    local prefix="  ${label}  "
    local mid="  ${pct_str}  "
    local used=$(( ${#prefix} + BAR_WIDTH + ${#mid} + ${#reset_display} ))
    local pad=$(( inner - used ))
    (( pad < 0 )) && pad=0

    # Print prefix
    printf ' %s%s' "$V" "$prefix"
    # Print progress bar directly (no subshell capture)
    progress_bar "$pct"
    # Print rest
    printf '%s' "$mid$reset_display"
    for (( i=0; i<pad; i++ )); do printf ' '; done
    printf '%s\n' "$V"
}

render_footer() {
    if $ONCE; then return; fi
    local remaining=$1
    local mins=$(( remaining / 60 ))
    local secs=$(( remaining % 60 ))
    printf '\n %b↻ Next refresh in %d:%02d  |  Ctrl+C to quit%b\n' "$DIM" "$mins" "$secs" "$RESET"
}

# --- Main Logic ---

fetch_and_render() {
    # Get accounts from helper
    local accounts_json
    accounts_json=$("$HELPER" decrypt 2>/dev/null) || {
        echo "No accounts found. Run: claude-dashboard-cli sync" >&2
        return 1
    }

    local count
    count=$(echo "$accounts_json" | jq 'length')

    # Clear screen and render header
    printf '\033[H\033[2J'
    render_header
    printf '\n'

    for (( i=0; i<count; i++ )); do
        local name plan status orgId sessionKey
        name=$(echo "$accounts_json" | jq -r ".[$i].name")
        plan=$(echo "$accounts_json" | jq -r ".[$i].plan")
        status=$(echo "$accounts_json" | jq -r ".[$i].status")
        orgId=$(echo "$accounts_json" | jq -r ".[$i].orgId")
        sessionKey=$(echo "$accounts_json" | jq -r ".[$i].sessionKey")

        if [[ "$status" != "active" || -z "$orgId" || "$orgId" == "null" || -z "$sessionKey" || "$sessionKey" == "null" ]]; then
            render_card "$name" "$plan" "$status" 0 "" 0 "" "" ""
            printf '\n'
            continue
        fi

        # Fetch usage
        local usage_json
        usage_json=$(curl -s --max-time 10 \
            -H "accept: */*" \
            -H "content-type: application/json" \
            -H "anthropic-client-platform: web_claude_ai" \
            -H "Cookie: sessionKey=$sessionKey" \
            "${API_BASE}/organizations/${orgId}/usage" 2>/dev/null) || usage_json="{}"

        local pct_5h pct_7d reset_5h_raw reset_7d_raw reset_5h reset_7d pct_sonnet reset_sonnet_raw reset_sonnet

        pct_5h=$(echo "$usage_json" | jq -r '.five_hour.utilization // 0' 2>/dev/null || echo 0)
        pct_7d=$(echo "$usage_json" | jq -r '.seven_day.utilization // 0' 2>/dev/null || echo 0)
        reset_5h_raw=$(echo "$usage_json" | jq -r '.five_hour.resets_at // ""' 2>/dev/null || echo "")
        reset_7d_raw=$(echo "$usage_json" | jq -r '.seven_day.resets_at // ""' 2>/dev/null || echo "")
        reset_5h=$(format_reset_time "$reset_5h_raw")
        reset_7d=$(format_reset_time "$reset_7d_raw")

        # Sonnet (optional)
        pct_sonnet=$(echo "$usage_json" | jq -r '.seven_day_sonnet.utilization // empty' 2>/dev/null || echo "")
        reset_sonnet_raw=$(echo "$usage_json" | jq -r '.seven_day_sonnet.resets_at // ""' 2>/dev/null || echo "")
        reset_sonnet=$(format_reset_time "$reset_sonnet_raw")

        render_card "$name" "$plan" "$status" \
            "$pct_5h" "$reset_5h" \
            "$pct_7d" "$reset_7d" \
            "$pct_sonnet" "$reset_sonnet"
        printf '\n'
    done
}

# --- Entry Point ---

# Check jq
if ! command -v jq &>/dev/null; then
    echo "Error: jq is required. Install via: brew install jq" >&2
    exit 1
fi

# Trap Ctrl+C for clean exit
trap 'printf "\033[?25h\n"; exit 0' INT TERM

# Hide cursor
printf '\033[?25l'

if $ONCE; then
    fetch_and_render
    printf '\033[?25h'
    exit 0
fi

while true; do
    fetch_and_render

    # Countdown
    for (( remaining=INTERVAL; remaining>0; remaining-- )); do
        render_footer "$remaining"
        sleep 1
        # Move cursor up to overwrite footer
        printf '\033[2A'
    done
done
